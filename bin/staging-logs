#!/usr/bin/env bash
# =============================================================================
# staging-logs — Tails logs for a staging service.
#
# Usage:
#   staging-logs [frontend|backend|<service>] [--config <path>]
# =============================================================================
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
K8_LIB_DIR="${K8_LIB_DIR:-$(cd "$SCRIPT_DIR/../../k8-lib" 2>/dev/null && pwd || echo "${HOME}/.local/share/k8-lib")}"
INFRA_ROOT="${INFRA_ROOT:-$(pwd)}"

# Pre-parse --config (must resolve before k8-lib sourcing)
for _k8_arg in "$@"; do
  case "$_k8_arg" in
    --config=*) export K8_CONFIG="${_k8_arg#--config=}" ;;
  esac
done
_k8_prev=""
for _k8_arg in "$@"; do
  [[ "$_k8_prev" == "--config" ]] && export K8_CONFIG="$_k8_arg"
  _k8_prev="$_k8_arg"
done
unset _k8_arg _k8_prev

source "$K8_LIB_DIR/bin/config.sh"
source "$K8_LIB_DIR/bin/common.sh"

NS="${K8_STAGING_NAMESPACE:-staging}"
APP_PREFIX="${K8_APP_PREFIX:-app}"

# Extract service name (first non-flag argument)
SERVICE="frontend"
EXTRA_ARGS=()
_skip_next=false
for arg in "$@"; do
  if $_skip_next; then _skip_next=false; continue; fi
  case "$arg" in
    --config) _skip_next=true ;;
    --config=*) ;;
    *)
      if [[ "$SERVICE" == "frontend" && ! "$arg" == --* ]]; then
        SERVICE="$arg"
      else
        EXTRA_ARGS+=("$arg")
      fi
      ;;
  esac
done
unset _skip_next

case "$SERVICE" in
  frontend) LABEL="app.kubernetes.io/name=${APP_PREFIX}-frontend" ;;
  backend)  LABEL="app.kubernetes.io/name=${APP_PREFIX}-backend" ;;
  *)        LABEL="app.kubernetes.io/name=${APP_PREFIX}-$SERVICE" ;;
esac

PODS=$(kubectl get pods -n "$NS" -l "$LABEL" --no-headers 2>/dev/null | wc -l | tr -d ' ')

if [[ "$PODS" == "0" ]]; then
  echo "No pods running for $SERVICE in $NS."
  echo "KEDA may have scaled to zero. Run: staging-status"
  echo "To wake up staging, curl your staging URL."
  exit 0
fi

kubectl logs -n "$NS" -l "$LABEL" --follow --all-containers "${EXTRA_ARGS[@]}"
