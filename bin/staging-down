#!/usr/bin/env bash
# =============================================================================
# staging-down — Uninstalls all staging Helm releases.
#
# Usage:
#   staging-down [--config <path>]
# =============================================================================
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
K8_LIB_DIR="${K8_LIB_DIR:-$(cd "$SCRIPT_DIR/../../k8-lib" 2>/dev/null && pwd || echo "${HOME}/.local/share/k8-lib")}"
INFRA_ROOT="${INFRA_ROOT:-$(pwd)}"

# Pre-parse --config (must resolve before k8-lib sourcing)
for _k8_arg in "$@"; do
  case "$_k8_arg" in
    --config=*) export K8_CONFIG="${_k8_arg#--config=}" ;;
  esac
done
_k8_prev=""
for _k8_arg in "$@"; do
  [[ "$_k8_prev" == "--config" ]] && export K8_CONFIG="$_k8_arg"
  _k8_prev="$_k8_arg"
done
unset _k8_arg _k8_prev

source "$K8_LIB_DIR/bin/config.sh"
source "$K8_LIB_DIR/bin/common.sh"

NS="${K8_STAGING_NAMESPACE:-staging}"

echo "Uninstalling staging releases from ${NS}..."

for release in $(helm list -n "$NS" -q 2>/dev/null); do
  echo "  Uninstalling $release..."
  helm uninstall "$release" -n "$NS" --wait
done

echo "Done."
